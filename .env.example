# PostgreSQL
DATABASE_URL=postgresql://hedgefund:hedgefund@postgres:5432/hedgefund

# Redis
REDIS_URL=redis://redis:6379/0

# API
API_HOST=0.0.0.0
API_PORT=8000
API_RATE_LIMIT=100

# External APIs (optional)
ALPHA_VANTAGE_API_KEY=
NEWS_API_KEY=
OPENAI_API_KEY=

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Cache
CACHE_TTL=300

# Logging
LOG_LEVEL=INFO

# --- V6 Trading Engine ---
TRADING_MODE=paper
INITIAL_CAPITAL=100000
SLIPPAGE_BPS=5
REBALANCE_THRESHOLD_PCT=2.0
MAX_POSITION_PCT=30.0
MAX_DAILY_LOSS_PCT=5.0
MAX_DRAWDOWN_PCT=15.0

# --- V7 TradingAgents (LLM signal provider) ---
# Disabled by default. Set TRADINGAGENTS_ENABLED=true to activate.
# Provider choices: openai | anthropic | gemini | ollama | mock
TRADINGAGENTS_ENABLED=false
TRADINGAGENTS_PROVIDER=mock
TRADINGAGENTS_MODEL=gpt-4o-mini
TRADINGAGENTS_DEPTH=1
TRADINGAGENTS_CACHE_TTL=3600
TRADINGAGENTS_STALE_TTL=86400
TRADINGAGENTS_MAX_CONCURRENT=2
TRADINGAGENTS_WEIGHT=0.4
TRADINGAGENTS_READ_TIMEOUT_S=2.0
TRADINGAGENTS_API_KEY=
